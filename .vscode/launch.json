// A launch configuration that compiles the extension and then opens it inside a new window
// Use IntelliSense to learn about possible attributes.
// Hover to view descriptions of existing attributes.
// For more information, visit: https://go.microsoft.com/fwlink/?linkid=830387
{
	"version": "0.2.0",
	"configurations": [
		{
			"name": "Run Extension",
			"type": "extensionHost",
			"request": "launch",
			"args": [
				"--extensionDevelopmentPath=${workspaceFolder}/packages/makerchip-extension",
				"--extensionDevelopmentPath=${workspaceFolder}/packages/tlv-extension"
			],
			"outFiles": [
				"${workspaceFolder}/packages/makerchip-extension/out/**/*.js",
				"${workspaceFolder}/packages/tlv-extension/out/**/*.js"
			],
			"preLaunchTask": "${defaultBuildTask}"
		},
		{
			"name": "Run TLV Extension (Desktop)",
			"type": "extensionHost",
			"request": "launch",
			"args": [
				"--extensionDevelopmentPath=${workspaceFolder}/packages/tlv-extension"
			],
			"outFiles": [
				"${workspaceFolder}/packages/tlv-extension/out/**/*.js"
			]
		},
		{
			"name": "Run TLV Extension (Web)",
			"type": "extensionHost",
			"debugWebWorkerHost": true,
			"request": "launch",
			"args": [
				"--extensionDevelopmentPath=${workspaceFolder}/packages/tlv-extension",
				"--extensionDevelopmentKind=web"
			],
			"outFiles": [
				"${workspaceFolder}/packages/tlv-extension/dist/web/**/*.js"
			]
		}
	]
}
