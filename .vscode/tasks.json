// VS Code Tasks Configuration for Makerchip Extension
//
// The default build task ("watch: all") starts TypeScript watch compilers for
// BOTH extensions on folder open and as the debug preLaunchTask:
//   - makerchip-extension: extension.ts + webview.ts (+ copies webview.html)
//   - tlv-extension: language extension (satisfies makerchip's hard
//     extensionDependencies so the dev host can load it from source)
// Each is a background watch with the $tsc-watch problem matcher, so edits
// recompile automatically. Reload the Extension Development Host window to pick
// up recompiled output.
//
// See https://go.microsoft.com/fwlink/?LinkId=733558 for tasks.json documentation
{
	"version": "2.0.0",
	"tasks": [
		{
			"label": "watch: makerchip",
			"type": "npm",
			"script": "watch",
			"path": "packages/makerchip-extension",
			"problemMatcher": "$tsc-watch",
			"isBackground": true,
			"presentation": {
				"reveal": "never",
				"group": "watch"
			},
			"group": "build"
		},
		{
			"label": "watch: tlv-extension",
			"type": "npm",
			"script": "watch",
			"path": "packages/tlv-extension",
			"problemMatcher": "$tsc-watch",
			"isBackground": true,
			"presentation": {
				"reveal": "never",
				"group": "watch"
			},
			"group": "build"
		},
		{
			"label": "watch: all",
			"dependsOn": [
				"watch: makerchip",
				"watch: tlv-extension"
			],
			"dependsOrder": "parallel",
			"problemMatcher": [],
			"group": {
				"kind": "build",
				"isDefault": true
			},
			"runOptions": {
				"runOn": "folderOpen"
			}
		}
	]
}
